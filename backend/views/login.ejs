<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        p{
            color: red;
        }
    </style>
</head>
<body>
    <form action="/signup/login" , method="post">
        <label >Email</label>
        <input type="text" , name = "email" , placeholder="exapmle@gmail.com">
        <label >Password</label>
        <input type="text " , name="password" , placeholder="123">
        <button type="submit">signup</button>
    </form>
    <% if (locals.msg) { %>
     <p>
        <%= msg %>
     </p>
    <% } %>
</body>
</html>